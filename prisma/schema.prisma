generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                String    @id @default(uuid())
  externalId        String    @unique
  cardmarketUrl     String?
  name              String
  expansion         String
  category          String
  releaseYear       Int?
  imageUrl          String?

  // === Cenové polia ===
  price             Float?    // Najlepšia vypočítaná cena (váhovaný priemer)
  currency          String?
  // Granulárne Cardmarket metriky
  trendPrice        Float?    // Cardmarket Trend Price
  fromPrice         Float?    // Cardmarket From Price (najlacnejší listing)
  oneDayAvg         Float?    // 1-day average price
  sevenDayAvg       Float?    // 7-day average price
  thirtyDayAvg      Float?    // 30-day average price
  // Metadáta o cene
  priceSource       String?   // 'cardmarket_scraper' | 'pokemon_api' | 'ebay' | 'manual'
  priceReason       String?   // Debug: dôvod výberu ceny (z PriceEngine)

  ebayUrl           String?
  ebayItemId        String?   @unique
  lastPriceSync     DateTime?
  availabilityCount Int?
  source            String    @default("cardmarket")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userAssets        UserAsset[]
  priceHistory      PriceHistory[]
  watchlistItems    WatchlistItem[]
}

model UserAsset {
  id              String    @id @default(uuid())
  userId          String
  name            String
  set             String
  category        String
  costBasis       Float
  currentValue    Float
  purchaseDate    DateTime
  imageUrl        String?
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  quantity        Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

model PriceHistory {
  id        String   @id @default(uuid())
  productId String
  price     Float
  availabilityCount Int?
  date      DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([date])
}

model Alert {
  id          String   @id @default(uuid())
  userId      String
  type        String   // 'price' | 'system' | 'availability'
  severity    String   // 'info' | 'warning' | 'critical'
  title       String
  description String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model WatchlistItem {
  id          String   @id @default(uuid())
  userId      String
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  targetPrice Float?
  addedAt     DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}
